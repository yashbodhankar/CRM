MONGODB_URI=mongodb://localhost:27017/crm_pro
PORT=5000

# Comma-separated allowed frontend origins
CORS_ORIGIN=http://localhost:3000

# Development only: set true to skip DB auth and use in-memory/dev credentials
DISABLE_AUTH=false

# Optional SMTP email delivery for notification events
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# JWT secret used to sign auth tokens
JWT_SECRET=change_this_in_production

# Seed an initial admin user on startup
SEED_ADMIN=true
ADMIN_NAME=Admin User
ADMIN_EMAIL=YASHBODHANKAR6@GMAIL.COM
ADMIN_PASSWORD=admin123
ADMIN_ROLE=admin
