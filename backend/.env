MONGODB_URI=mongodb+srv://yash:<db_password>@cluster0.koowd8l.mongodb.net/?appName=Cluster0
PORT=5003

# Development: set to true to skip MongoDB and allow dev login (uses ADMIN_EMAIL/ADMIN_PASSWORD)
DISABLE_AUTH=true

# JWT secret used to sign auth tokens
JWT_SECRET=change_this_in_production

# Seed an initial admin user on startup
SEED_ADMIN=true
ADMIN_NAME=Admin User
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
ADMIN_ROLE=admin
